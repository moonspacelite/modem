#!/bin/sh

. /lib/functions.sh

NCM_MAC="00:00:11:12:13:14"
LOCKFILE="/var/run/l850gl-scan.lock"

exec 200>"$LOCKFILE"
flock -n 200 || exit 0

at_command() {
    local port="$1"
    local cmd="$2"
    ( flock -x 200; COMMAND="$cmd" gcom -d "$port" -s /etc/gcom/getrun_at.gcom 2>/dev/null ) 200>"$port"
}

verify_at_port() {
    local port="$1"
    [ -c "$port" ] || return 1
    # Coba beberapa kali karena ModemManager mungkin baru lepas
    for i in 1 2 3; do
        output=$(at_command "$port" "ATI")
        if echo "$output" | grep -q "OK"; then
            if echo "$output" | grep -qi "Fibocom\|L850"; then
                logger -t "l850gl-scan" "Port AT valid: $port"
                return 0
            fi
        fi
        sleep 1
    done
    # Fallback: cukup cek AT
    if at_command "$port" "AT" | grep -q "OK"; then
        logger -t "l850gl-scan" "Port AT fallback (AT only): $port"
        return 0
    fi
    return 1
}

find_at_port() {
    for port in /dev/ttyACM* /dev/ttyUSB*; do
        [ -e "$port" ] || continue
        if verify_at_port "$port"; then
            echo "$port"
            return 0
        fi
    done
    return 1
}

find_ncm_iface() {
    local retries=20 i=0
    while [ $i -lt $retries ]; do
        for netdev in /sys/class/net/*; do
            [ -d "$netdev" ] || continue
            [ -f "$netdev/address" ] && [ "$(cat "$netdev/address")" = "$NCM_MAC" ] && {
                iface="$(basename "$netdev")"
                logger -t "l850gl-scan" "Interface NCM ditemukan: $iface"
                echo "$iface"
                return 0
            }
        done
        i=$((i+1))
        sleep 1
    done
    return 1
}

main() {
    logger -t "l850gl-scan" "Memulai pemindaian..."
    at_port=$(find_at_port) || {
        logger -t "l850gl-scan" "ERROR: Port AT tidak ditemukan."
        return 1
    }
    ncm_iface=$(find_ncm_iface) || {
        logger -t "l850gl-scan" "ERROR: Interface NCM tidak ditemukan."
        return 1
    }
    uci -q batch <<UCI_EOF
delete network.wwan
set network.wwan=interface
set network.wwan.proto='atc'
set network.wwan.device='$at_port'
set network.wwan.ifname='$ncm_iface'
set network.wwan.apn='internet'
set network.wwan.delay='15'
set network.wwan.metric='10'
set network.wwan.auto='1'
commit network
UCI_EOF
    logger -t "l850gl-scan" "UCI diperbarui: device=$at_port ifname=$ncm_iface"
    return 0
}

main
exit $?
