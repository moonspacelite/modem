#!/bin/sh
#
# l850gl-scan - Deteksi modem Fibocom L850-GL secara robust (mirip QModem)
#

. /lib/functions.sh

NCM_MAC="00:00:11:12:13:14"
LOCKFILE="/var/run/l850gl-scan.lock"

# Hindari eksekusi bersamaan
exec 200>"$LOCKFILE"
flock -n 200 || {
    logger -t "l850gl-scan" "Proses scan sudah berjalan, keluar."
    exit 0
}

# Fungsi untuk mengirim AT command dan mendapatkan output
# Menggunakan gcom dengan script getrun_at.gcom
send_at_command() {
    local port="$1"
    local cmd="$2"
    COMMAND="$cmd" gcom -d "$port" -s /etc/gcom/getrun_at.gcom 2>/dev/null
}

# Fungsi untuk memverifikasi apakah port adalah port AT modem L850-GL
verify_at_port() {
    local port="$1"
    local output

    [ -c "$port" ] || return 1

    # Kirim ATI (AT Identification)
    output=$(send_at_command "$port" "ATI")

    # Periksa apakah output mengandung 'OK' dan salah satu identifier Fibocom/L850
    if echo "$output" | grep -q "OK" && \
       ( echo "$output" | grep -qi "Fibocom" || echo "$output" | grep -qi "L850" ); then
        logger -t "l850gl-scan" "Port AT valid ditemukan: $port"
        return 0
    fi

    return 1
}

# Cari port AT yang valid
find_at_port() {
    local port
    for port in /dev/ttyACM* /dev/ttyUSB*; do
        [ -e "$port" ] || continue
        if verify_at_port "$port"; then
            echo "$port"
            return 0
        fi
    done
    return 1
}

# Cari interface NCM dengan MAC unik
find_ncm_iface() {
    local netdev addr_file iface
    local retries=15

    local i=0
    while [ "$i" -lt "$retries" ]; do
        for netdev in /sys/class/net/*; do
            [ -d "$netdev" ] || continue
            addr_file="$netdev/address"
            if [ -f "$addr_file" ] && [ "$(cat "$addr_file" 2>/dev/null)" = "$NCM_MAC" ]; then
                iface="$(basename "$netdev")"
                logger -t "l850gl-scan" "Interface NCM ditemukan: $iface"
                echo "$iface"
                return 0
            fi
        done
        i=$((i + 1))
        sleep 1
    done

    logger -t "l850gl-scan" "ERROR: Interface NCM dengan MAC $NCM_MAC tidak ditemukan."
    return 1
}

# Fungsi utama
main() {
    local at_port ncm_iface

    logger -t "l850gl-scan" "Memulai pemindaian modem Fibocom L850-GL..."

    at_port=$(find_at_port)
    if [ -z "$at_port" ]; then
        logger -t "l850gl-scan" "ERROR: Tidak ada port AT yang valid."
        return 1
    fi

    ncm_iface=$(find_ncm_iface)
    if [ -z "$ncm_iface" ]; then
        logger -t "l850gl-scan" "ERROR: Interface NCM tidak ditemukan."
        return 1
    fi

    # Perbarui konfigurasi UCI network.wwan
    uci -q batch <<UCI_EOF
delete network.wwan
set network.wwan=interface
set network.wwan.proto='atc'
set network.wwan.device='$at_port'
set network.wwan.ifname='$ncm_iface'
set network.wwan.apn='internet'
set network.wwan.delay='15'
set network.wwan.metric='10'
set network.wwan.auto='1'
commit network
UCI_EOF

    logger -t "l850gl-scan" "UCI network.wwan diperbarui. device=$at_port, ifname=$ncm_iface"
    return 0
}

main
exit $?
