#!/bin/sh
#
# l850gl-init - wrapper untuk scanner dan ifup/ifdown
#

ACTION="$1"
LOCKFILE="/var/run/l850gl-init.lock"

exec 200>"$LOCKFILE"
flock -n 200 || exit 0

case "$ACTION" in
    add)
        logger -t "l850gl" "Init: memulai scan dan ifup"
        /usr/bin/l850gl-scan && ifup wwan
        ;;
    remove)
        logger -t "l850gl" "Init: mematikan wwan"
        ifdown wwan 2>/dev/null
        uci -q delete network.wwan
        uci commit network
        ;;
    *)
        echo "Usage: $0 {add|remove}"
        exit 1
        ;;
esac
